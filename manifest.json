{
  "manifest_version": 3,
  "name": "رابط واضح - Clear URL",
  "description": "انسخ الروابط العربية والروابط متعددة اللغات بشكل واضح ومقروء، مع خيار إزالة روابط التتبع.",
  "version": "1.0.0",
  "author": "LARIS",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "contextMenus",
    "notifications",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "رابط واضح",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}